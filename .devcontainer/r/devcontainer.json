{
  "name": "analysis-r",
  "build": {
    "dockerfile": "../../docker/r/Dockerfile",
    "context": "../.."
  },
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind"
  ],
  "forwardPorts": [8888],
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "ms-toolsai.jupyter",
        "GitHub.vscode-github-actions"
      ],
      "settings": {
        "r.rterm.linux": "/usr/local/bin/R",
        "r.bracketedPaste": true
      }
    }
  }
}
